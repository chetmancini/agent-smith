{
  "name": "agent-smith-app",
  "version": "0.1.0",
  "private": true,
  "description": "Standalone TypeScript CLI for Agent Smith telemetry, rollups, reports, and live watch flows",
  "type": "module",
  "bin": {
    "agent-smith": "dist/cli.js"
  },
  "scripts": {
    "build": "bun build ./src/cli.ts --outfile ./dist/cli.js --target bun",
    "format": "biome format src tests",
    "lint": "biome lint src tests --error-on-warnings",
    "test": "bun test --coverage",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/bun": "^1.3.2",
    "@types/node": "^24.7.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
