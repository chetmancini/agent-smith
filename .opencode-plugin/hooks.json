{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_SMITH_TOOL=opencode bash ./hooks/session-start.sh",
            "timeout": 10,
            "statusMessage": "Recording Agent Smith session start..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_SMITH_TOOL=opencode bash ./hooks/tool-failure.sh",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_SMITH_TOOL=opencode bash ./hooks/test-result.sh",
            "timeout": 60,
            "statusMessage": "Running tests..."
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_SMITH_TOOL=opencode bash ./hooks/permission-denied.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_SMITH_TOOL=opencode bash ./hooks/vague-prompt.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_SMITH_TOOL=opencode COMPACT_TRIGGER=auto bash ./hooks/compact.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "manual",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_SMITH_TOOL=opencode COMPACT_TRIGGER=manual bash ./hooks/compact.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_SMITH_TOOL=opencode AGENT_SMITH_DEFAULT_STOP_REASON=turn_complete bash ./hooks/session-stop.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "AGENT_SMITH_TOOL=opencode bash ./hooks/analyze-trigger.sh",
            "timeout": 10,
            "async": true
          }
        ]
      }
    ]
  }
}
